# BPS Stat Agent Environment Variables
# Copy this file to .env and fill in your values

# LLM API Key (required - choose one)
# ANTHROPIC_AUTH_TOKEN=your-anthropic-api-key
# OPENAI_API_KEY=your-openai-api-key
# MINIMAX_API_KEY=your-minimax-api-key

# BPS WebAPI Key (required for BPS data access)
# BPS_API_KEY=your-bps-api-key

# Optional: BPS Configuration
# BPS_DEFAULT_DOMAIN=5300
# BPS_SEARCH_DELAY=10

# Optional: Logging
# LOG_LEVEL=INFO
# LOG_JSON_OUTPUT=false
